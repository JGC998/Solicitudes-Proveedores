# ─────────────────────────────────────────────────────────────────────────────
# RFQ Manager — Configuración de entorno
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copia este archivo como ".env":         cp .env.example .env
# 2. Rellena los valores de tu entorno
# 3. Nunca subas el .env al repositorio (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────


# ─── Sesiones ────────────────────────────────────────────────────────────────
# Cadena aleatoria para firmar las cookies de sesión.
# En desarrollo puede ser cualquier texto; en producción usa al menos 32 chars aleatorios.
# Ejemplo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia-esto-por-algo-seguro-en-produccion


# ─── URL base del servidor ───────────────────────────────────────────────────
# Dirección completa desde la que los usuarios acceden a la app.
# Se usa en los botones de los emails para que el enlace funcione en la red.
#
# ▸ Desarrollo en local (solo tu máquina):
#   APP_URL=http://localhost:3000
#
# ▸ Desarrollo en red local (otros dispositivos en tu WiFi):
#   Obtén tu IP con: node -e "const os=require('os');console.log(Object.values(os.networkInterfaces()).flat().find(n=>n.family==='IPv4'&&!n.internal)?.address)"
#   APP_URL=http://192.168.1.100:3000
#
# ▸ Producción:
#   APP_URL=https://rfq.tuempresa.com
APP_URL=http://localhost:3000


# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Si dejas SMTP_PASS vacío, el sistema usará Ethereal Email (modo prueba):
#   - Los emails NO se envían de verdad
#   - Puedes verlos en https://ethereal.email/messages
#   - Las credenciales de Ethereal aparecen en la consola al arrancar
#
# Para usar Gmail real necesitas una "Contraseña de aplicación":
#   1. Activa verificación en dos pasos → myaccount.google.com/security
#   2. Busca "Contraseñas de aplicación" en esa misma página
#   3. Crea una nueva: tipo "Correo" → "Otro" → nombre "RFQ Manager"
#   4. Google te da 16 caracteres — cópialos aquí tal cual (con o sin espacios)
#
# Para usar otro proveedor SMTP (Outlook, SendGrid, etc.) cambia host y puerto.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=


# ─── Integración con API externa ─────────────────────────────────────────────
# URL base de la API del sistema de gestión de la empresa.
# Deja vacío para trabajar en modo demo (sin integración).
#
# RFQ Manager espera estos dos endpoints en esa URL base:
#   GET  {EXTERNAL_API_URL}/productos   → devuelve lista de productos
#   POST {EXTERNAL_API_URL}/pedidos     → recibe un pedido adjudicado
#
# Ver migracionAPI.md para instrucciones detalladas de cómo adaptarlo.

EXTERNAL_API_URL=
EXTERNAL_API_KEY=
